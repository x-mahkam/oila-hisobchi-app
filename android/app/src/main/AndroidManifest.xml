<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 11+ (API 30+) paket ko'rinishi cheklovi: tizimning nutqni
         tanib olish xizmatini (SpeechToTextPlugin.java) topish/ulash uchun
         majburiy — bo'lmasa SpeechRecognizer ishlamay qoladi. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Push bildirishnomalarni ko'rsatish uchun (Android 13 / API 33+ da shart,
         aks holda tizim ruxsatni so'rashning o'zi ishlamaydi va bildirishnomalar
         hech qachon ko'rinmaydi). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Biometrik autentifikatsiya (barmoq izi / yuz tanish) uchun. -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <!-- QR-kod skaner (kamera) va ovoz bilan kiritish (mikrofon) uchun —
         WebView'dagi getUserMedia()/SpeechRecognition so'rovlari ushbu
         manifest ruxsatlari bo'lmasa tizim darajasida rad etiladi (ruxsat
         so'rash oynasi umuman chiqmaydi). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Hisobot/tilxat fayllarini "Yuklab olishlar" papkasiga saqlash uchun —
         faqat Android 9 va pastda (API<=28) kerak; Android 10+ da MediaStore
         orqali maxsus ruxsatsiz ishlaydi (SaveToDownloadsPlugin.java'ga q.). -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />
</manifest>
