rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kirishdan oldin yoki bola (anonim) uchun kerak bo'lgan hujjatlar.
    // tphone_, em_, kidlogin_ : login qidirish (maxfiy ma'lumot yo'q)
    // vazifa_, kidbal_, notif_, user_ : vazifa tizimi (bola anonim ishlatadi)
    match /appdata/{docId} {
      allow read: if request.auth != null
        || docId.matches('oilaV7_tphone_.*')
        || docId.matches('oilaV7_em_.*')
        || docId.matches('oilaV7_kidlogin_.*');
      allow write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
