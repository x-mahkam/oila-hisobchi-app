rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
//  OILA HISOBCHI — Firestore Security Rules
//  Sodda, bardoshli, get()-ga minimal bog'liq versiya.
//
//  Asosiy himoya: har hujjatда `_u` (yozuvchi auth uid) va ko'p
//  hujjatlarda `_o` (oilaId) yorlig'i bor (firebase.js → db.s).
//   • O'z hujjatingiz (_u == uid) — to'liq ruxsat.
//   • Oila a'zosi hujjati (_o == mening oilam) — o'qish/yozish.
//   • Login-qidiruv (em_/tphone_/kidlogin_...) — kirish uchun ochiq.
//   • Boshqa hammasi — YOPIQ.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function DB()       { return 'oilaV7_'; }

    // user_<uid> hujjatining butun data'si (mavjud bo'lsa).
    function userData() {
      return get(/databases/$(database)/documents/appdata/$(DB() + 'user_' + uid())).data;
    }
    function sessData() {
      return get(/databases/$(database)/documents/appdata/$(DB() + 'ksess_' + uid())).data;
    }
    function hasUser() {
      return exists(/databases/$(database)/documents/appdata/$(DB() + 'user_' + uid()));
    }
    function hasSess() {
      return exists(/databases/$(database)/documents/appdata/$(DB() + 'ksess_' + uid()));
    }
    // Mening oilaId'im: user_<uid>.v.oilaId (bo'lsa) yoki ksess_<uid>.oila (bola).
    function myOila() {
      return hasUser()
        ? (('v' in userData()) && ('oilaId' in userData().v) ? userData().v.oilaId : 'NONE')
        : (hasSess()
            ? (('oila' in sessData()) ? sessData().oila : 'NONE')
            : 'NONE');
    }

    // Hujjat docId'sida mening oilaId'im bormi? (masalan maq_<oila>, x_<oila>_<uid>)
    //  Bu get()-ning ichma-ich .v.oilaId muammosini chetlab o'tuvchi bardoshli usul:
    //  docId ichida "_<myOila>" ketma-ketligi bo'lsa — mening oilamniki.
    function docHasMyOila(id) {
      return myOila() != 'NONE' && id.matches('.*_' + myOila() + '(_.*)?');
    }

    // Hujjat docId'si mening uid'im bilan tugaydimi? (notif_<uid>, xreq_<uid>)
    //  Bunday hujjatlar shaxsan menга atalgan — o'qish/yozish ruxsat.
    function docIsMyUid(id) {
      return signedIn() && id.matches('.*_' + uid());
    }

    // Login-qidiruv hujjatlari (kirishdan oldin ochiq bo'lishi shart).
    function isLookup(id) {
      return id.matches('oilaV7_(tphone|em|tel|tel9|kidlogin)_.*');
    }

    // Hujjat menikimi: _u == mening uid'im (get() talab qilmaydi — arzon).
    function mineByUser(res) {
      return res != null && ('_u' in res.data) && res.data._u == uid();
    }
    // Hujjat oilamnikimi: _o == mening oilam (get() bir marta).
    function mineByOila(res) {
      return res != null && ('_o' in res.data) && res.data._o == myOila();
    }

    // Yangi yozuv yorlig'i: _u majburan mening uid'im.
    function writeOk() {
      return signedIn() && ('_u' in request.resource.data)
             && request.resource.data._u == uid();
    }

    // Qarz-pochta (qmail): qi_<toTel>_<id>, `c: "qreq_<toTel>"`.
    //  Yuboruvchi yozadi (writeOk), qabul qiluvchi o'z kanalini o'qiydi.
    function myTel() {
      return hasUser() && ('v' in userData()) && ('tel' in userData().v)
        ? userData().v.tel : 'NONE';
    }
    function myChannel(res) {
      return res != null && ('c' in res.data) && res.data.c == ('qreq_' + myTel());
    }

    // Oila hujjati (oila_<id>): join qilish uchun kirgan foydalanuvchi
    //  oila mavjudligini va a'zolar limitini bilishi kerak. O'qish — kirgan
    //  har kimga ochiq (maxfiy moliyaviy tafsilot yo'q: faqat nomi/limit).
    //  YOZISH esa himoyalangan (quyida writeOk/docHasMyOila orqali).
    function isOilaDoc(id) { return id.matches('oilaV7_oila_.*'); }

    match /appdata/{docId} {

      // O'z profilim va sessiyam — har doim ruxsat.
      function isMine() {
        return docId == (DB() + 'user_' + uid())
            || docId == (DB() + 'ksess_' + uid());
      }

      allow read: if isLookup(docId)
                  || (signedIn() && isOilaDoc(docId))
                  || (signedIn() && isMine())
                  || (signedIn() && mineByUser(resource))
                  || (signedIn() && mineByOila(resource))
                  || (signedIn() && docHasMyOila(docId))
                  || (signedIn() && docIsMyUid(docId))
                  || (signedIn() && myChannel(resource));

      allow create: if signedIn() && (isMine() || isLookup(docId) || writeOk() || docHasMyOila(docId) || docIsMyUid(docId));

      allow update: if signedIn() && (
                       isMine() || isLookup(docId)
                       || (writeOk() && (mineByUser(resource) || mineByOila(resource)))
                       || docHasMyOila(docId) || docIsMyUid(docId)
                    );

      allow delete: if signedIn() && (mineByUser(resource) || mineByOila(resource) || docHasMyOila(docId) || docIsMyUid(docId) || myChannel(resource));
    }

    match /{document=**} { allow read, write: if false; }
  }
}
