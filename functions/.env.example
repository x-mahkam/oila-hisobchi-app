# Cloud Functions muhit o'zgaruvchilari (namuna).
# Haqiqiy qiymatlarni functions/.env fayliga yozing (u git'ga qo'shilmasin).

# Admin panel: admin Firebase Auth UID'lari (vergul bilan). Bo'sh bo'lsa admin amallari yopiq.
ADMIN_UIDS=

# RevenueCat webhook maxfiy kaliti (Authorization sarlavhasi bilan mos bo'lishi shart).
# Bo'sh bo'lsa webhook yopiq (fail-closed).
REVENUECAT_WEBHOOK_SECRET=

# Google Play Service Account JSON (premium xaridni serverda tekshirish uchun).
GOOGLE_PLAY_SERVICE_ACCOUNT=
